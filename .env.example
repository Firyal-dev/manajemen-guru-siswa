APP_NAME=ManajemenGuruSiswa
APP_ENV=local
APP_KEY=
# PRODUCTION: set APP_DEBUG=false (true leaks stack traces, env vars, DB creds on error)
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=management-siswa
# PRODUCTION: use a dedicated least-privilege DB user, NOT root, and set a strong password.
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCTION: set SESSION_ENCRYPT=true (encrypts session payload at rest in the sessions table).
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# PRODUCTION: set SESSION_SECURE_COOKIE=true (send session cookie only over HTTPS).
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Cross-app master-data API secret consumed by management-nilai as X-API-KEY.
# Generate a fresh random value per environment; NEVER commit the real token.
# Example: php -r "echo bin2hex(random_bytes(32));"
API_ACCESS_TOKEN=
